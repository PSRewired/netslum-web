    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.15.2",
    "bootstrap": "^5.3.8",
    "deepmerge": "^4.3.1",
    "formik": "^2.4.9",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.12.0",
    "react": "^19.2.6",
    "react-bootstrap": "^3.0.0-beta.5",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.5.12",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
